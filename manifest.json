{
  "manifest_version": 3,
  "name": "PromptReady",
  "version": "1.0.0",
  "description": "Automatically enhance AI prompts using proven frameworks. Works on ChatGPT, Claude, Gemini, Perplexity, Grok, and DeepSeek.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://grok.x.com/*",
    "https://x.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://grok.x.com/*",
        "https://x.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content/prompt_analyzer.js",
        "content/framework_selector.js",
        "content/prompt_rewriter.js",
        "content/ui_overlay.js",
        "content/content.js"
      ],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
